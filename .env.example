# VelaFlow Beta 0.1.0 example environment
# Copy this file to .env for local testing. Do not commit real API keys.

VELAFLOW_MODE=LOCAL

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-flash-latest

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_FALLBACK_TEXT_MODEL=

XAI_API_KEY=
XAI_TEXT_MODEL=grok-4.3
XAI_FALLBACK_TEXT_MODEL=

DEFAULT_AI_PROVIDER=gemini
TEXT_AI=gemini
IMAGE_AI=manual
VIDEO_AI=manual

AI_RETRY_COUNT=3
AI_BACKOFF_BASE_SECONDS=2
AI_REQUEST_TIMEOUT=60
AI_CACHE_ENABLED=true
AI_QUEUE_WORKERS=3

OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium

FLUX_API_URL=
FLUX_API_KEY=
SDXL_API_URL=
SDXL_API_KEY=
IMAGE_REQUEST_TIMEOUT=180
IMAGE_CACHE_ENABLED=true

VIDEO_REQUEST_TIMEOUT=300
KLING_API_URL=
KLING_API_KEY=
RUNWAY_API_URL=
RUNWAY_API_KEY=
GOOGLE_FLOW_API_URL=
GOOGLE_FLOW_API_KEY=
LUMA_API_URL=
LUMA_API_KEY=
PIXVERSE_API_URL=
PIXVERSE_API_KEY=
VEO_API_URL=
VEO_API_KEY=

QUALITY_MODE=balanced
FFMPEG_PATH=ffmpeg
